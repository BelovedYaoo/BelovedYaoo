.container {
  height: 100%;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  flex-direction: row;
  justify-content: center;
  padding-top: 50px;
}

.avatar {
  width: 300px;
  height: 150px;
  display: flex;
}

.circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid #ffffff;
}

.textContainer {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 30px;
}

.title,
.showTime,
.yiyan {
  display: flex;
  justify-content: center;
}

.title {
  font-size: large;
  font-weight: bolder;
}

.showTime,
.yiyan {
  font-size: medium;
  font-weight: bolder;
}

.yiyan {
  margin-top: 25px;
  transition: opacity 0.6s;
}

.toTangshi {
  margin-top: 200px;
}