.container {
  height: 100%;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  flex-direction: row;
  justify-content: center;
  padding-top: 30px;
}

.avatar {
  width: 300px;
  height: 150px;
  display: flex;
}

.circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid #ffffff;
}

.textContainer {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 50px;
}

.title,
.showTime,
.yiyan {
  display: flex;
  justify-content: center;
}

.title {
  font-size: large;
  font-weight: bolder;
}

.showTime,
.yiyan {
  font-size: medium;
  font-weight: bolder;
}

.yiyan {
  margin-top: 25px;
  transition: opacity 0.6s;
}

.toTangshi {
  margin-top: 200px;
}

.swiper-item image,
.swiper-item video {
  width: 100%;
  display: block;
  height: 100%;
  margin: 0;
  pointer-events: none;
}

image {
  max-width: 100%;
  display: inline-block;
  position: relative;
  z-index: 0;
}

.swiper-box {
  height: 650rpx;
  position: relative;
  max-width: 750rpx;
  overflow: hidden;
  box-sizing: border-box;
  margin-top: 0rpx;
}

.swiper-box .item-box {
  position: absolute;
  width: 350rpx;
  height: 470rpx;
  top: 0;
  bottom: 0;
  left: 47%;
  margin: auto;
  transition: all 0.2s ease-in 0s;
  opacity: 1;
  box-shadow: 0px 12rpx 19rpx rgba(134, 134, 134, 0.5);
  border-radius: 15rpx;
  overflow: hidden;
}

.swiper-box .item-box.none {
  opacity: 0;
}

.swiper-box .item-box .swiper-item {
  width: 100%;
  height: 100%;
  border-radius: 6rpx;
  overflow: hidden;
}

.swiper-box .item-box {
  transform: scale(calc(0.5 + var(--index) / 10));
  margin-left: calc(var(--left) * 100rpx - 150rpx);
  z-index: var(--index);
}