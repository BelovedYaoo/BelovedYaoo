page {
  height: calc(100% - constant(safe-area-inset-bottom) - 170rpx);
  height: calc(100% - env(safe-area-inset-bottom) - 170rpx);
  padding-bottom: calc(constant(safe-area-inset-bottom) + 170rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 170rpx);
}

.app {
  display: flex;
  justify-content: center;
  flex-direction: column;
}

.full-screen-bg {
  position: fixed;
  z-index: -1;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-repeat: no-repeat;
  background-position: center;
  background-size: cover;
}

.full-screen-bg {
  background-image: url("data:image/jpeg;base64,");
}